#!/usr/bin/env bash
set -euo pipefail

ITEM_PREFIX="Docker Credential: "
LOCK_FILE="${XDG_RUNTIME_DIR:-/tmp}/docker-credential-op.lock"

item_name_for() {
  printf '%s%s' "$ITEM_PREFIX" "$1"
}

cmd_get() {
  local server_url item_name json username secret
  server_url="$(cat)"
  item_name="$(item_name_for "$server_url")"

  if ! json="$(flock "$LOCK_FILE" op item get "$item_name" --format json 2>/dev/null)"; then
    echo "credentials not found in native keychain"
    exit 1
  fi

  username="$(jq -r '.fields[]? | select(.label=="username") | .value // empty' <<<"$json")"
  secret="$(jq -r '.fields[]? | select(.label=="password") | .value // empty' <<<"$json")"

  if [[ -z "$username" || -z "$secret" ]]; then
    echo "credentials not found in native keychain"
    exit 1
  fi

  jq -n --arg su "$server_url" --arg u "$username" --arg s "$secret" \
    '{ServerURL: $su, Username: $u, Secret: $s}'
}

main() {
  local subcommand="${1:-}"
  case "$subcommand" in
    get)   cmd_get ;;
    *)
      echo "Operation {subcommand} is not implemented" >&2
      exit 1
      ;;
  esac
}

main "$@"
