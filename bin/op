#!/usr/bin/env bash
set -euo pipefail

readonly _KERNEL="$(uname -r)"

op() {
    if [[ "$_KERNEL" =~ [Mm]icrosoft ]]; then
        op.exe "$@"
    elif [[ "$_KERNEL" =~ orbstack ]]; then
        mac op "$@"
    else
        command op "$@"
    fi
}

cmd_run() {
    local account=""
    local -a cmd_args=()
    local found_sep=false

    while [ $# -gt 0 ]; do
        if [ "$found_sep" = true ]; then
            cmd_args+=("$1")
        elif [ "$1" = "--" ]; then
            found_sep=true
        elif [ "$1" = "--account" ] && [ $# -gt 1 ]; then
            account="$2"
            shift
        elif [[ "$1" == -* ]]; then
            echo "op: unsupported flag for WSL wrapper: $1" >&2
            exit 1
        else
            echo "op: unexpected argument: $1" >&2
            exit 1
        fi
        shift
    done

    if [ ${#cmd_args[@]} -eq 0 ]; then
        echo "op: 'op run' requires a command after '--'" >&2
        exit 1
    fi

    local -a read_flags=()
    [ -n "$account" ] && read_flags=("--account" "$account")

    # Resolve environment variables with op:// references before exec
    while IFS= read -r line; do
        local name="${line%%=*}"
        local value="${line#*=}"
        if [[ "$value" == op://* ]]; then
            local resolved
            resolved=$(op read "${read_flags[@]}" "$value" </dev/null) || {
                echo "op: failed to read secret for $name" >&2
                exit 1
            }
            export "${name}=${resolved}"
        fi
    done < <(env)

    exec "${cmd_args[@]}"
}

case "${1-}" in
    run)
        shift
        cmd_run "$@"
        ;;
    *)
        op "$@"
        ;;
esac
